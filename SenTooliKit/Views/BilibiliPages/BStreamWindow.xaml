<Window x:Class="SenTooliKit.Views.BilibiliPages.BStreamWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:SenTooliKit.Views.BilibiliPages"
        MouseLeftButtonDown="BStreamWindow_OnMouseLeftButtonDown"
        xmlns:components="clr-namespace:SenTooliKit.Views.Components"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:SenTooliKit.ViewModels.BilibiliPages"
        d:DataContext="{d:DesignInstance vm:BStreamWindowViewModel, IsDesignTimeCreatable=True}"
        mc:Ignorable="d"
        Title="BStreamWindow" Height="450" Width="800">
  <Border
    BorderBrush="Purple"
    BorderThickness="1">
    <Grid Margin="5">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition />
      </Grid.RowDefinitions>
      <components:TitleBar />
      <Grid Grid.Row="1">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition />
        </Grid.RowDefinitions>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80*" />
            <ColumnDefinition Width="20*" />
          </Grid.ColumnDefinitions>
          <Border>
            <StackPanel>
              <TextBox
                Text="{Binding Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                materialDesign:HintAssist.Hint="请输入直播链接"
                Style="{StaticResource MaterialDesignFilledTextBox}" />
              
            </StackPanel>
          </Border>
          <Button
            VerticalAlignment="Top"
            Command="{Binding StopStreamCommand}"
            Grid.Column="1"
            Height="40"
            Background="Red">
            停止录制
          </Button>
          <Button
            VerticalAlignment="Top"
            Command="{Binding DownloadStreamAndShowInfoCommand}"
            Grid.Column="1"
            Height="40"
            Visibility="{Binding DownloadButtonVisibility}">
            直播录制
          </Button>
        </Grid>
        <ProgressBar
          VerticalAlignment="Bottom"
          BorderBrush="Transparent"
          Background="Transparent"
          Grid.Row="0"
          IsIndeterminate="{Binding IsDownloading}"/>
        <ScrollViewer Grid.Row="1">
          <TextBox
            Grid.Row="1" Text="{Binding StreamDetailInfo}"
            TextWrapping="Wrap"
            IsEnabled="False" />
        </ScrollViewer>
      </Grid>
    </Grid>
  </Border>
</Window>