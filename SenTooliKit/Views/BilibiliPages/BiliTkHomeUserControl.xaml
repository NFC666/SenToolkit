<UserControl x:Class="SenTooliKit.Views.BilibiliPages.BiliTkHomeUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SenTooliKit.Views"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:SenTooliKit.ViewModels"
             xmlns:converter="clr-namespace:SenTooliKit.Converter"
             xmlns:components="clr-namespace:SenTooliKit.Views.Components"
             xmlns:bilibiliPages="clr-namespace:SenTooliKit.ViewModels.BilibiliPages"
             mc:Ignorable="d"
             d:DesignHeight="400"
             d:DesignWidth="600"
             d:DataContext="{d:DesignInstance Type=bilibiliPages:BiliTkHomeUserControlVM, IsDesignTimeCreatable=True}">
  <UserControl.Resources>
    <converter:IconSizeConverter x:Key="IconSizeConverter" />
  </UserControl.Resources>
  <StackPanel>
    <StackPanel Margin="10">
      <TextBlock
        Style="{StaticResource MaterialDesignTitleLargeTextBlock}">
        b站工具包
      </TextBlock>
      <Border BorderBrush="Gray" Opacity="0.2" BorderThickness="0,0,0,1"></Border>
      <ItemsControl ItemsSource="{Binding Tools}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="{x:Type vm:ToolItemViewModel}">
            <Border VerticalAlignment="Center" HorizontalAlignment="Center">
              <Button
                Margin="10"
                Height="80"
                Style="{StaticResource MaterialDesignPaperLightButton}"
                Command="{Binding OpenWindowCommand}"
                Width="{Binding Height,RelativeSource={RelativeSource Self}}">
                <Button.Content>
                  <Border>
                    <StackPanel>
                      <md:PackIcon
                        Height="{Binding FontSize,ElementName=TextBlock,Converter={StaticResource IconSizeConverter}}"
                        Width="{Binding Height,RelativeSource={RelativeSource Self}}"
                        HorizontalAlignment="Center"
                        Kind="{Binding Icon}" />
                      <TextBlock
                        x:Name="TextBlock"
                        TextAlignment="Center"
                        TextWrapping="Wrap"
                        FontSize="12"

                        Text="{Binding Title}" />
                    </StackPanel>
                  </Border>
                </Button.Content>
              </Button>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </StackPanel>
</UserControl>