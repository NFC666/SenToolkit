<UserControl x:Class="SenTooliKit.Views.BilibiliPages.BCommentInfoUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SenTooliKit.Views.BilibiliPages"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:m="clr-namespace:SenTooliKit.Common.Models;assembly=SenTooliKit.Common"
             xmlns:vm="clr-namespace:SenTooliKit.ViewModels.BilibiliPages"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:BCommentInfoUserControlVM, IsDesignTimeCreatable=True}"
             d:DesignHeight="600" d:DesignWidth="900">
  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition />
    </Grid.RowDefinitions>
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="80*" />
        <ColumnDefinition Width="20*" />
      </Grid.ColumnDefinitions>
      <Border>
        <StackPanel>
          <TextBox
            Text="{Binding Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            materialDesign:HintAssist.Hint="输入视频评论区"
            Style="{StaticResource MaterialDesignFilledTextBox}" />
        </StackPanel>
      </Border>
      <Button
        VerticalAlignment="Top"
        Command="{Binding GetCommentsCommand}"
        Grid.Column="1"
        Height="40">
        获取评论
      </Button>
    </Grid>
    <ProgressBar Grid.Row="0" VerticalAlignment="Bottom"
                 BorderBrush="Transparent"
                 Background="Transparent"
                 IsIndeterminate="{Binding IsLoading}"
                 />
    <TreeView Grid.Row="1"
              ItemsSource="{Binding Replies}"
              VirtualizingStackPanel.IsVirtualizing="True"
              VirtualizingStackPanel.VirtualizationMode="Recycling"
              VirtualizingPanel.IsVirtualizingWhenGrouping="True"
              ScrollViewer.CanContentScroll="True">
      <TreeView.Resources>

        <HierarchicalDataTemplate DataType="{x:Type m:Reply}" ItemsSource="{Binding Replies}">
          <StackPanel Margin="5">
            <TextBlock Text="{Binding SenderId}" FontWeight="Bold" />
            <TextBlock Text="{Binding Content.Message}" TextWrapping="Wrap" />
            <TextBlock Text="{Binding Like, StringFormat=Likes: {0}}" FontStyle="Italic" />
          </StackPanel>
        </HierarchicalDataTemplate>
      </TreeView.Resources>
      <TreeView.ItemsPanel>

        <ItemsPanelTemplate>

          <VirtualizingStackPanel />
        </ItemsPanelTemplate>
      </TreeView.ItemsPanel>
    </TreeView>
  </Grid>
</UserControl>