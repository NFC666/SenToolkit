<UserControl x:Class="SenTooliKit.Views.BilibiliPages.BDmAnalysisUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:vm="clr-namespace:SenTooliKit.ViewModels.BilibiliPages"
             xmlns:scottplot="http://schemas.scottplot.net/2008/xaml/presentation"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             d:DataContext="{d:DesignInstance vm:BDmAnalysisUserControlVM, IsDesignTimeCreatable=True}"
             d:DesignHeight="800" d:DesignWidth="1200">
  <ScrollViewer Margin="10">
    <StackPanel>
      <TextBox
        Style="{StaticResource MaterialDesignFilledTextBox}"
        Text="{Binding Url}"
        materialDesign:HintAssist.Hint="输入视频链接"
        TextWrapping="NoWrap" />
      <Button Content="分析目标视频"
              Command="{Binding SearchAndAnalysisCommand}" />
      <GroupBox
        Margin="0,10"
        Height="400" Header="弹幕分析柱状图">
        <ContentControl
          IsEnabled="False"
          Content="{Binding Plot1, Mode=OneTime}" />
      </GroupBox>
      <Grid Height="400">
        <Grid.ColumnDefinitions>
          <ColumnDefinition />
          <ColumnDefinition />

        </Grid.ColumnDefinitions>
        <GroupBox

          Header="弹幕分析饼状图">
          <ContentControl
            IsEnabled="False"
            Margin="10"
            Content="{Binding PiePlot, Mode=OneTime}" />
        </GroupBox>
      </Grid>
    </StackPanel>
  </ScrollViewer>
</UserControl>