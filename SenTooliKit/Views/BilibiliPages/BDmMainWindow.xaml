<Window x:Class="SenTooliKit.Views.BilibiliPages.BDmMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:SenTooliKit.Views.BilibiliPages"
        mc:Ignorable="d"
        xmlns:m="clr-namespace:SenTooliKit.Common.Models;assembly=SenTooliKit.Common"
        xmlns:vm="clr-namespace:SenTooliKit.ViewModels.LoginPages"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        MouseLeftButtonDown="BulletMainWindow_OnMouseLeftButtonDown"
        xmlns:bilibiliPages="clr-namespace:SenTooliKit.ViewModels.BilibiliPages"
        xmlns:components="clr-namespace:SenTooliKit.Views.Components"
        d:DataContext="{d:DesignInstance bilibiliPages:BDmWindowViewModel, IsDesignTimeCreatable=True}"
        Style="{StaticResource MaterialDesignWindow}"
        Title="BDmMainWindow" Height="800" Width="1200">
  <Border
    BorderBrush="DarkMagenta"
    BorderThickness="1"
    Margin="1">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <Border>
        <components:TitleBar />
      </Border>
      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border
          Width="150"
          Grid.Column="0">
          <ListBox
            SelectedItem="{Binding SelectedItem}"
            ItemsSource="{Binding BulletPages}">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Title}" />
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Border>

        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentPage}" />
      </Grid>
    </Grid>
  </Border>
</Window>