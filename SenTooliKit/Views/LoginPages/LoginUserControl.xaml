<UserControl x:Class="SenTooliKit.Views.LoginPages.LoginUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SenTooliKit.Views.LoginPages"
             xmlns:converter="clr-namespace:SenTooliKit.Converter"

             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
  <UserControl.Resources>
    <converter:PathToImageConverter x:Key="PathToImageConverter" />
  </UserControl.Resources>
  <StackPanel Grid.Row="1"
              VerticalAlignment="Center"
              HorizontalAlignment="Center">
    <TextBlock
      Margin="4"
      FontSize="15"
      FontWeight="Bold"
      HorizontalAlignment="Center"
      Text="{Binding StateText}" />
    <Image
      Visibility="{Binding IsQrCodeShow}"
      Height="200" Width="200"
      Source="{Binding QrCodePath
          ,Converter={StaticResource PathToImageConverter}}" />
    <StackPanel
      HorizontalAlignment="Right"
      Orientation="Horizontal">
      <TextBlock
        VerticalAlignment="Bottom"

        Style="{StaticResource MaterialDesignLabelSmallTextBlock}"
        Text="工具出问题了？" />
      <Button
        Command="{Binding LoginAgainCommand}"
        Height="20"
        Style="{StaticResource MaterialDesignFlatButton}">
        <TextBlock
          HorizontalAlignment="Right"
          Style="{StaticResource MaterialDesignLabelSmallTextBlock}"
          Text="重新登录" />
      </Button>
    </StackPanel>
  </StackPanel>
</UserControl>