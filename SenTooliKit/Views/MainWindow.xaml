<Window x:Class="SenTooliKit.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:SenTooliKit.Views"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        MouseLeftButtonDown="MainWindow_OnMouseLeftButtonDown"
        xmlns:vm="clr-namespace:SenTooliKit.ViewModels;assembly=SenTooliKit"
        xmlns:converter="clr-namespace:SenTooliKit.Converter"
        Title="MainWindow" Height="450" Width="800">
  <Window.Resources>
    <converter:PathToImageConverter x:Key="PathToImageConverter" />
  </Window.Resources>
  <Border
    Margin="1"
    BorderBrush="Purple"
    BorderThickness="1">
    <materialDesign:DrawerHost
      OpenMode="Standard"
      x:Name="DrawerHost"
      BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
      BorderThickness="2">
      <materialDesign:DrawerHost.Style>
        <Style TargetType="materialDesign:DrawerHost">
          <Style.Triggers>
            <DataTrigger
              Binding="{Binding IsChecked, ElementName=BackgroundToggle}"
              Value="True">
              <Setter
                Property="OverlayBackground"
                Value="{DynamicResource MaterialDesign.Brush.Primary}" />
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </materialDesign:DrawerHost.Style>
      <materialDesign:DrawerHost.LeftDrawerContent>
        <StackPanel>
          <TextBlock
            Margin="4"
            FontSize="15"
            FontWeight="Bold"
            HorizontalAlignment="Left"
            Text="工具盒" />
          <ListBox 
            ItemsSource="{Binding Items}"
            SelectedItem="{Binding SelectedItem}"/>
        </StackPanel>
      </materialDesign:DrawerHost.LeftDrawerContent>
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <DockPanel LastChildFill="False">

          <Button
            Click="ButtonBase_OnClick"
            Style="{StaticResource MaterialDesignFlatButton}"
            DockPanel.Dock="Right"
            Margin="4">
            <materialDesign:PackIcon Kind="Close" />
          </Button>
          <Button
            Click="WindowRestore"
            Style="{StaticResource MaterialDesignFlatButton}"
            DockPanel.Dock="Right"
            Margin="4">
            <materialDesign:PackIcon Kind="WindowRestore" />
          </Button>
          <Button
            Click="WindowMinimize"
            Style="{StaticResource MaterialDesignFlatButton}"
            DockPanel.Dock="Right"
            Margin="4">
            <materialDesign:PackIcon Kind="Minus" />
            
          </Button>
          <Button
            Style="{StaticResource MaterialDesignFlatButton}"
            DockPanel.Dock="Left"
            Click="BackgroundToggle_OnClick"
            Margin="4"
            x:Name="BackgroundToggle">
            <materialDesign:PackIcon Kind="Menu" />
          </Button>
        </DockPanel>
        
        <ContentControl Grid.Row="1" Content="{Binding CurrentPage}"/>
      </Grid>
    </materialDesign:DrawerHost>
  </Border>
</Window>